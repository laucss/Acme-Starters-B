acme.validation.header.message  	= Must have from 1 to 75 characters
acme.validation.text.message   		= Must have from 1 to 255 characters

acme.validation.duplicated-ticker.message	= The ticker is duplicated
acme.validation.ticker.message				= The ticker must start with two uppercase letters and two digits, followed by a hyphen and 5 to 10 letters, digits, or underscores

acme.validation.invalid-time-interval.message = Start moment must be before end moment

acme.validation.startMoment-is-not-in-the-future.message = Start moment must be in the future 
acme.validation.endMoment-is-not-in-the-future.message = End moment must be in the future

acme.validation.already-published.message = It is already published
acme.validation.invalid-time-interval.message = Start moment must be before end moment
acme.validation.invalid-currency.message = Money currency must be euros


acme.validation.invention.published-without-parts.message = Inventions cannot be published unless they have at least one part

acme.validation.strategy.published-without-tactics.message = A strategy cannot be published unless it has at least one tactic 

acme.validation.campaign.published-without-milestone.message = A campaign cannot be published unless it has at least one milestone
 
acme.validation.sponsorship.published-without-donations.message = A sponsorship cannot be published unless it has at least one donation
 
acme.validation.report.published-without-sections.message = A report cannot be published unless it has at least one section

acme.validation.project.published-without-inventions.message = A project cannot be published unless they have at least one invention

acme.validation.duplicated-title.message = The title is duplicated

acme.validation.invalid-project-time-interval.message = Kick off moment must be before close out moment 

projectMember.create.validation.NoUserSelected = There is no user selected

acme.validation.project.only-published-with-reports.message = Only published projects can have reports
acme.validation.project.only-published-with-sponsorships.message = Only published projects can have sponsorships

acme.validation.project.effortNotCero-without-members.message = A project must have members in order to have components
